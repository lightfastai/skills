    "eval:foundation": "node ./scripts/run-baml-eval.mjs foundation-creator",
    "eval:spec": "node ./scripts/run-baml-eval.mjs spec-creator"
  },
  "dependencies": {
    "@boundaryml/baml": "0.221.0",
    "typescript": "5.9.3"
  }
}
